# PostgreSQL — required for Prisma. With `docker compose up -d postgres` use:
DATABASE_URL="postgresql://skooly:skooly@localhost:5432/skooly"

# Timetable CP-SAT optimizer — optional; use same secret as Python service (see services/timetable-solver/README.md)
TIMETABLE_SOLVER_ENABLED=1
TIMETABLE_SOLVER_URL=http://localhost:8000
TIMETABLE_SOLVER_SECRET=dev-secret
