generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NEW: School model acting as the Tenant
model School {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // E4: used to iterate term dates in local school time.
  // Store IANA timezone names (e.g. "Africa/Cairo") to correctly handle DST.
  timezone String @default("UTC")

  /// E7: when false, commit-style scheduling (term generation commit, DS recurring commit) is blocked; dry-runs and reads still allowed.
  schedulingPipelineEnabled Boolean @default(true)

  gradingScale Float @default(100)

  auths               Auth[]
  admins              Admin[]
  teachers            Teacher[]
  parents             Parent[]
  students            Student[]
  grades              Grade[]
  classes             Class[]
  subjects            Subject[]
  lessons             Lesson[]
  exams               Exam[]
  assignments         Assignment[]
  results             Result[]
  attendances         Attendance[]
  events              Event[]
  announcements       Announcement[]
  teacherAvailability TeacherAvailability[]

  // Scheduling (Phase 2/3/5)
  terms              Term[]
  periods            Period[]
  calendarExceptions SchoolCalendarException[]
  lessonSessions     LessonSession[]
  examTemplates      ExamTemplate[]

  termScheduleGenerationLogs TermScheduleGenerationLog[]
  recurringExamCommitLogs      RecurringExamCommitLog[]
  lessonSessionOverrideAudits  LessonSessionOverrideAudit[]
  calendarExceptionAudits      CalendarExceptionAudit[]

  subscriptions SchoolSubscription[]

  stripeCustomerId String? @unique

  academicYears        AcademicYear[] @relation("SchoolAcademicYears")
  activeAcademicYearId String?        @unique
  activeAcademicYear   AcademicYear?  @relation("ActiveSchoolYear", fields: [activeAcademicYearId], references: [id], onDelete: SetNull)

  curricula Curriculum[]

  scheduleChangeRequests ScheduleChangeRequest[]

  rooms Room[] @relation("SchoolRooms")

  gradingScales  GradingScale[]
  promotionRules PromotionRules[]
  joinCodes      JoinCode[]
  memberships    SchoolMembership[]

  timetableGradeTemplates TimetableGradeTemplate[]

  /// ISO 3166-1 alpha-2 (e.g. MA, FR). Used to filter curriculum catalog templates.
  country         String?
  /// Normalized slug: national_morocco, ib_myp, custom, etc.
  teachingSystem  String?

  marketplaceSettings    SchoolMarketplaceSettings?
  marketplaceInvitations MarketplaceInvitation[]
  marketplaceEngagements MarketplaceEngagement[]
  marketplaceNeeds       SchoolMarketplaceNeed[]

  @@index([name])
}

model Auth {
  id          String      @id @default(cuid())
  username    String      @unique
  email       String?     @unique
  password    String
  role        String
  schoolId    String?
  accountType AccountType @default(SCHOOL_ADMIN)
  displayName String?
  avatarUrl   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt

  admin   Admin?
  teacher Teacher?
  student Student?
  parent  Parent?
  school  School?  @relation(fields: [schoolId], references: [id])

  systemAdmin SystemAdmin?
  memberships SchoolMembership[]

  @@index([email])
  @@index([role])
}

model Admin {
  id       String  @id @default(cuid())
  username String  @unique
  name     String?
  surname  String?
  phone    String?
  img      String?
  authId   String  @unique
  auth     Auth    @relation(fields: [authId], references: [id])

  schoolId   String
  school     School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  memberships SchoolMembership[]
}

model Student {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String
  surname   String
  email     String?  @unique
  phone     String?  @unique
  address   String
  img       String?
  bloodType String
  sex       UserSex
  createdAt DateTime @default(now())
  birthday  DateTime
  authId    String   @unique
  auth      Auth     @relation(fields: [authId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  parentId String
  parent   Parent @relation(fields: [parentId], references: [id])

  classId Int?
  class   Class? @relation(fields: [classId], references: [id], onDelete: SetNull)

  gradeId Int?
  grade   Grade? @relation(fields: [gradeId], references: [id], onDelete: SetNull)

  attendances Attendance[]
  results     Result[]

  enrollmentHistory StudentEnrollmentHistory[]
  memberships       SchoolMembership[]
}

model Teacher {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String
  surname   String
  email     String?  @unique
  phone     String?  @unique
  address   String
  img       String?
  bloodType String
  sex       UserSex
  createdAt DateTime @default(now())
  birthday  DateTime
  authId    String   @unique
  auth      Auth     @relation(fields: [authId], references: [id])

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  subjects       Subject[]
  lessons        Lesson[]
  lessonSessions LessonSession[]
  lessonSessionsAsSubstitute LessonSession[] @relation("LessonSessionSubstitute")
  classes        Class[]
  availability   TeacherAvailability[]

  requestedChanges ScheduleChangeRequest[] @relation("RequestedChanges")
  proposedSwaps    ScheduleChangeRequest[] @relation("ProposedSwaps")
  memberships      SchoolMembership[]

  examTemplates ExamTemplate[]

  marketplaceProfile      TeacherMarketplaceProfile?
  marketplaceInvitations  MarketplaceInvitation[]
  marketplaceEngagements  MarketplaceEngagement[]
  marketplaceApplications MarketplaceApplication[]
}

model Parent {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String
  surname   String
  email     String?  @unique
  phone     String?
  address   String
  createdAt DateTime @default(now())
  authId    String   @unique
  auth      Auth     @relation(fields: [authId], references: [id])

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  students    Student[]
  memberships SchoolMembership[]
}

model Grade {
  id    Int    @id @default(autoincrement())
  level String

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  students Student[]
  classes  Class[]

  curriculumSubjects Curriculum[]
  promotionRules     PromotionRules[]

  timetableGradeTemplates TimetableGradeTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([level, schoolId])
}

/// Whole-school timetable assistant: editable per-grade requirement prototype (no classId in rowsJson).
model TimetableGradeTemplate {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gradeId  Int
  grade    Grade  @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  /// JSON array: { subjectId, teacherId, periodsPerWeek, blockSize, roomId? }[]
  rowsJson Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, gradeId])
  @@index([schoolId])
}

model Class {
  id       Int    @id @default(autoincrement())
  name     String
  capacity Int

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  supervisorId String?
  supervisor   Teacher? @relation(fields: [supervisorId], references: [id])

  lessons        Lesson[]
  lessonSessions LessonSession[]
  students       Student[]

  gradeId Int
  grade   Grade @relation(fields: [gradeId], references: [id])

  events        Event[]
  announcements Announcement[]

  enrollmentHistory StudentEnrollmentHistory[]
  joinCodes         JoinCode[]

  examTemplates ExamTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, schoolId, academicYearId])
}

model Subject {
  id   Int    @id @default(autoincrement())
  name String

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  teachers       Teacher[]
  lessons        Lesson[]
  lessonSessions LessonSession[]
  examTemplates  ExamTemplate[]

  curriculumGrades Curriculum[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, schoolId])
}

model Lesson {
  id        Int      @id @default(autoincrement())
  name      String
  day       Day
  startTime DateTime
  endTime   DateTime

  // Phase 3: optional mapping to a bell schedule period (time block)
  periodId String?
  period   Period? @relation(fields: [periodId], references: [id], onDelete: SetNull)
  // Multi-period span: end period for double/triple block (null = single period)
  endPeriodId String?
  endPeriod   Period? @relation("LessonEndPeriod", fields: [endPeriodId], references: [id], onDelete: SetNull)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  roomId Int?
  room   Room? @relation("RoomLessons", fields: [roomId], references: [id], onDelete: SetNull)

  deliveryMode LessonDeliveryMode @default(IN_PERSON)

  /// Live meeting link when `deliveryMode` is ONLINE (e.g. Zoom/Meet).
  meetingUrl   String?
  /// Short label shown next to the link (e.g. "Zoom", "Teams").
  meetingLabel String?

  // Phase 5: generated dated sessions
  lessonSessions LessonSession[]

  exams          Exam[]
  // Legacy assignment linkage (source lesson/content lesson)
  assignments    Assignment[] @relation("AssignmentSourceLesson")
  // E1 due linkage (assignment due on a specific lesson)
  dueAssignments Assignment[] @relation("AssignmentDueLesson")
  attendances    Attendance[]

  scheduleChangeRequests ScheduleChangeRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, day, teacherId, startTime, endTime])
  @@index([schoolId, day, classId, startTime, endTime])
  @@index([schoolId, day, roomId, startTime, endTime])
}

// Phase 5: generated dated lesson instance (one per template lesson per session date)
model LessonSession {
  id Int @id @default(autoincrement())

  termId String
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  templateLessonId Int
  templateLesson   Lesson @relation(fields: [templateLessonId], references: [id], onDelete: Cascade)

  sessionDate DateTime
  day         Day

  name      String
  startTime DateTime
  endTime   DateTime

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  roomId Int?
  room   Room? @relation("RoomLessonSessions", fields: [roomId], references: [id], onDelete: SetNull)

  deliveryMode LessonDeliveryMode @default(IN_PERSON)

  meetingUrl   String?
  meetingLabel String?

  status LessonSessionStatus @default(SCHEDULED)

  substituteTeacherId String?
  substituteTeacher   Teacher? @relation("LessonSessionSubstitute", fields: [substituteTeacherId], references: [id], onDelete: SetNull)

  overrideRoomId Int?
  overrideRoom   Room? @relation("LessonSessionOverrideRoom", fields: [overrideRoomId], references: [id], onDelete: SetNull)

  instanceNotes      String?  @db.Text
  lastOverrideReason String? @db.Text
  lastOverrideAt     DateTime?

  overrideAudits LessonSessionOverrideAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templateLessonId, sessionDate])
  @@index([termId, sessionDate])
  @@index([schoolId, classId, sessionDate])
  @@index([schoolId, teacherId, sessionDate])
}

// Phase 5: weekly exam template generates Exam rows for each date in a Term
model ExamTemplate {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  termId String
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  title String?

  day       Day
  startTime DateTime
  endTime   DateTime

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  roomId Int?
  room   Room? @relation("RoomExamTemplates", fields: [roomId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exams Exam[]

  @@index([termId, day, classId])
}

model Exam {
  id        Int      @id @default(autoincrement())
  title     String
  startTime DateTime
  endTime   DateTime
  maxScore  Float    @default(100)
  weight    Float    @default(1.0)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  results Result[]

  lessonId Int?
  lesson   Lesson? @relation(fields: [lessonId], references: [id])

  examPeriodId String?
  examPeriod   SchoolCalendarException? @relation("ExamPeriodExams", fields: [examPeriodId], references: [id], onDelete: SetNull)

  durationMinutes Int     @default(60)
  isRecurring     Boolean @default(false)
  examCategory    ExamCategory @default(COURSE_EXAM)

  // Phase 5: generated exam instances
  termId String?
  term   Term?   @relation(fields: [termId], references: [id], onDelete: SetNull)

  examTemplateId String?
  examTemplate   ExamTemplate? @relation(fields: [examTemplateId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examTemplateId, startTime])
  @@index([termId])
  @@index([examTemplateId])
  @@index([schoolId, startTime, endTime])
  @@index([schoolId, lessonId, startTime, endTime])
  @@index([schoolId, termId, startTime])
  @@index([examPeriodId])
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  dueDate   DateTime // Legacy compatibility field (dual-read fallback)
  startDate DateTime
  maxScore  Float    @default(100)
  weight    Float    @default(1.0)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  results Result[]

  lessonId Int?
  lesson   Lesson? @relation("AssignmentSourceLesson", fields: [lessonId], references: [id], onDelete: SetNull)

  dueLessonId Int?
  dueLesson   Lesson? @relation("AssignmentDueLesson", fields: [dueLessonId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, dueDate])
  @@index([schoolId, dueLessonId])
  @@index([schoolId, lessonId])
}

model Result {
  id             Int      @id @default(autoincrement())
  score          Float
  comments       String?
  submissionDate DateTime @default(now())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  examId Int?
  exam   Exam? @relation(fields: [examId], references: [id])

  assignmentId Int?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([examId])
  @@index([assignmentId])
}

model Attendance {
  id     Int              @id @default(autoincrement())
  date   DateTime
  status AttendanceStatus

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  lessonId Int
  lesson   Lesson @relation(fields: [lessonId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, date])
  @@index([academicYearId])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classId Int?
  class   Class? @relation(fields: [classId], references: [id], onDelete: Cascade)

  roomId Int?
  room   Room? @relation("RoomEvents", fields: [roomId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])
}

model SystemAdmin {
  id     String  @id @default(cuid())
  authId String  @unique
  auth   Auth    @relation(fields: [authId], references: [id])
  name   String?
}

model SubscriptionPlan {
  id                String               @id @default(cuid())
  name              String               @unique
  price             Float
  currency          String
  billingCycle      BillingCycle // MONTHLY or YEARLY
  stripePriceId     String               @unique // Stripe Price ID
  features          String[] // List of features
  maxStudents       Int? // Added field
  maxTeachers       Int? // Added field
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  SchoolSubcription SchoolSubscription[]
}

model SchoolSubscription {
  id                   String             @id @default(cuid())
  schoolId             String
  school               School             @relation(fields: [schoolId], references: [id])
  subscriptionPlanId   String
  subscriptionPlan     SubscriptionPlan   @relation(fields: [subscriptionPlanId], references: [id])
  stripeSubscriptionId String             @unique // Stripe Subscription ID
  status               SubscriptionStatus // ACTIVE, CANCELED, PAST_DUE, etc.
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  endDate              DateTime? // Added field
  nextBillingDate      DateTime? // Added field
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([schoolId])
  @@index([stripeSubscriptionId])
}

model AcademicYear {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation("SchoolAcademicYears", fields: [schoolId], references: [id], onDelete: Cascade)
  name       String // e.g., "2023-2024", "First Semester 2024"
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(false) // Is this the currently active year for operations?
  isArchived Boolean  @default(false) // Is this year concluded and data archived?

  /// Last curriculum catalog template applied to this year (audit).
  catalogTemplateId      String?
  catalogTemplateVersion String?
  catalogInstalledAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation to the school that has this as its active year (if any)
  activeForSchool School? @relation("ActiveSchoolYear")

  classes           Class[]
  curricula         Curriculum[]
  enrollmentHistory StudentEnrollmentHistory[]
  promotionRules    PromotionRules[]
  attendances       Attendance[]

  // Scheduling (Phase 2/3/5)
  terms Term[]

  @@unique([schoolId, name])
  @@index([schoolId, isActive])
}

enum CalendarExceptionType {
  HOLIDAY
  BREAK
  EXAM_PERIOD
}

// E5: per-generated-session edits (does not mutate Lesson template)
enum LessonSessionStatus {
  SCHEDULED
  CANCELLED
}

/// Weekly template / session: in-person vs live online (both count toward teacher overlap).
enum LessonDeliveryMode {
  IN_PERSON
  ONLINE
}

/// E6: distinguishes in-class pop quizzes (calendar badge) from full course exams.
enum ExamCategory {
  COURSE_EXAM
  POP_QUIZ
}

// Phase 2: temporal container (e.g., Fall / Spring / Semester)
model Term {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  name      String
  startDate DateTime
  endDate   DateTime

  isActive   Boolean @default(false)
  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calendarExceptions SchoolCalendarException[]
  lessonSessions     LessonSession[]
  examTemplates      ExamTemplate[]
  exams              Exam[]

  termScheduleGenerationLogs TermScheduleGenerationLog[]
  recurringExamCommitLogs    RecurringExamCommitLog[]
  calendarExceptionAudits    CalendarExceptionAudit[]

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId, isActive])
}

// E4: audit trail for term lesson generation runs (dry-run + commit)
model TermScheduleGenerationLog {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  termId String
  term   Term @relation(fields: [termId], references: [id], onDelete: Cascade)

  requestId     String
  idempotencyKey  String
  mode            String // dryRun | commit
  scopeType       String // school | grade | class
  scopeGradeId    Int?
  scopeClassId    Int?

  durationMs  Int
  success     Boolean @default(true)
  errorCode   String?

  // Full summary payload (counts, skippedByReason, conflict list length / snapshot)
  summaryJson String @db.Text

  createdAt DateTime @default(now())

  @@index([schoolId, termId, createdAt])
  @@index([schoolId, idempotencyKey, mode])
}

/// E7: audit trail for DS recurring exam commit runs.
model RecurringExamCommitLog {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  termId String
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  requestId    String
  durationMs   Int
  success      Boolean @default(true)
  examsCreated Int     @default(0)
  errorCode    String?
  summaryJson  String  @db.Text

  createdAt DateTime @default(now())

  @@index([schoolId, termId, createdAt])
}

/// E7: immutable audit rows for admin lesson-session instance overrides (PATCH).
model LessonSessionOverrideAudit {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  lessonSessionId Int
  lessonSession   LessonSession @relation(fields: [lessonSessionId], references: [id], onDelete: Cascade)

  actorAuthId String?
  patchJson   String  @db.Text

  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([lessonSessionId])
}

/// Calendar exception mutation audit rows (create/update/delete).
model CalendarExceptionAudit {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  termId String
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  exceptionId String?
  exception   SchoolCalendarException? @relation(fields: [exceptionId], references: [id], onDelete: SetNull)

  actorAuthId String?
  operation   String
  beforeJson  String? @db.Text
  afterJson   String? @db.Text

  createdAt DateTime @default(now())

  @@index([schoolId, termId, createdAt])
  @@index([exceptionId, createdAt])
}

// Phase 3: bell schedule period templates (time blocks)
model Period {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name       String // e.g., "Period 1", "Lunch"
  startTime  DateTime
  endTime    DateTime
  order      Int
  isArchived Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessonTemplates    Lesson[]
  lessonTemplatesEnd Lesson[] @relation("LessonEndPeriod")

  @@unique([schoolId, name])
  @@index([schoolId, order])
}

// Phase 2 exceptions: school calendar blocks within a term
model SchoolCalendarException {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  termId String
  term   Term   @relation(fields: [termId], references: [id], onDelete: Cascade)

  title     String
  type      CalendarExceptionType @default(HOLIDAY)
  startDate DateTime
  endDate   DateTime
  notes     String?               @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exams Exam[] @relation("ExamPeriodExams")
  audits CalendarExceptionAudit[]

  @@index([termId, type])
}

model Curriculum {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  gradeId Int
  grade   Grade @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: NoAction)

  description      String?
  /// Deprecated: use `CurriculumBook`. Retained for DB compatibility; new writes go through Books.
  textbook         String?
  /// Free-form units/chapters/pacing (Markdown-friendly in UI).
  syllabusOutline  String? @db.Text
  syllabusUrl      String?
  coefficient      Float   @default(1.0)
  /// Optional weekly period count for timetable planning (nullable = not specified).
  periodsPerWeek   Int?

  books CurriculumBook[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([academicYearId, gradeId, subjectId])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([gradeId])
  @@index([subjectId])
}

enum CurriculumBookRole {
  primary
  supplementary
  workbook
  reader
  teacher
  digital
  other
}

/// Teaching resources linked to one curriculum row (year × grade × subject).
model CurriculumBook {
  id           String             @id @default(cuid())
  curriculumId String
  curriculum   Curriculum         @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  sortOrder    Int                @default(0)
  title        String
  authors      String?
  isbn         String?
  publisher    String?
  edition      String?
  role         CurriculumBookRole @default(primary)
  notes        String?            @db.Text
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([curriculumId])
}

model StudentEnrollmentHistory {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  classId Int
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  enrollmentDate DateTime         @default(now())
  departureDate  DateTime?
  status         EnrollmentStatus @default(ENROLLED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, classId])
  @@index([studentId])
  @@index([classId])
  @@index([academicYearId])
}

enum UserSex {
  MALE
  FEMALE
  OTHER
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  UNPAID
}

enum EnrollmentStatus {
  ENROLLED
  PROMOTED
  REPEATED
  WITHDRAWN
  COMPLETED
  GRADUATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum AccountType {
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
  SYSTEM_ADMIN
}

enum JoinCodeType {
  CLASS_STUDENT
  TEACHER_INVITE
  PARENT_LINK
}

model TeacherAvailability {
  id          String   @id @default(cuid())
  dayOfWeek   Day // MONDAY, TUESDAY, etc.
  startTime   DateTime // Store as full DateTime, but only time part is relevant for daily availability
  endTime     DateTime // Store as full DateTime, but only time part is relevant for daily availability
  isAvailable Boolean // True if available, False if this is a blocked/unavailable slot
  notes       String?  @db.Text

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, dayOfWeek, startTime, schoolId]) // Ensure unique slot per teacher, day, time, school
  @@index([teacherId])
  @@index([schoolId])
}

// NEW Enums for ScheduleChangeRequest
enum ScheduleChangeType {
  TIME_CHANGE
  SWAP
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

// NEW Model for ScheduleChangeRequest
model ScheduleChangeRequest {
  id                    String             @id @default(cuid())
  requestingTeacherId   String
  requestingTeacher     Teacher            @relation("RequestedChanges", fields: [requestingTeacherId], references: [id], onDelete: Cascade)
  lessonId              Int
  lesson                Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  requestedChangeType   ScheduleChangeType
  proposedStartTime     DateTime? // For TIME_CHANGE
  proposedEndTime       DateTime? // For TIME_CHANGE
  proposedDay           Day? // For TIME_CHANGE, uses existing Day enum
  proposedSwapTeacherId String? // For SWAP
  proposedSwapTeacher   Teacher?           @relation("ProposedSwaps", fields: [proposedSwapTeacherId], references: [id], onDelete: NoAction, onUpdate: NoAction) // Nullable, NoAction to avoid cycles on delete
  reason                String             @db.Text
  status                RequestStatus      @default(PENDING)
  adminNotes            String?            @db.Text

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestingTeacherId])
  @@index([lessonId])
  @@index([proposedSwapTeacherId])
  @@index([schoolId])
  @@index([status])
}

model GradingScale {
  id        String      @id @default(cuid())
  schoolId  String
  school    School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  maxScore  Float
  isDefault Boolean     @default(false)
  bands     GradeBand[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([schoolId, name])
}

model GradeBand {
  id             String       @id @default(cuid())
  gradingScaleId String
  gradingScale   GradingScale @relation(fields: [gradingScaleId], references: [id], onDelete: Cascade)
  label          String
  abbreviation   String?
  minPercentage  Float
  maxPercentage  Float
  gpaEquivalent  Float?
  color          String?
  isPassing      Boolean
  order          Int

  @@unique([gradingScaleId, label])
  @@index([gradingScaleId])
}

model PromotionRules {
  id                    String       @id @default(cuid())
  schoolId              String
  school                School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYearId        String
  academicYear          AcademicYear @relation(fields: [academicYearId], references: [id])
  gradeId               Int?
  grade                 Grade?       @relation(fields: [gradeId], references: [id])
  passingThreshold      Float        @default(50)
  minimumOverallAverage Float        @default(50)
  maxFailedSubjects     Int          @default(2)
  minimumAttendance     Float        @default(75)
  borderlineMargin      Float        @default(5)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@unique([schoolId, academicYearId, gradeId])
}

model JoinCode {
  id          String       @id @default(cuid())
  code        String       @unique
  schoolId    String
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  type        JoinCodeType
  classId     Int?
  class       Class?       @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId   String?
  email       String?
  maxUses     Int?
  currentUses Int          @default(0)
  expiresAt   DateTime?
  isActive    Boolean      @default(true)
  createdBy   String
  createdAt   DateTime     @default(now())

  @@index([code])
  @@index([schoolId])
}

model SchoolMembership {
  id       String   @id @default(cuid())
  authId   String
  auth     Auth     @relation(fields: [authId], references: [id], onDelete: Cascade)
  schoolId String
  school   School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  role     String
  isActive Boolean  @default(true)
  joinedAt DateTime @default(now())

  admin   Admin?  @relation(fields: [adminId], references: [id])
  adminId String?

  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  teacherId String?

  student   Student? @relation(fields: [studentId], references: [id])
  studentId String?

  parent   Parent? @relation(fields: [parentId], references: [id])
  parentId String?

  @@unique([authId, schoolId, role])
  @@index([authId])
  @@index([schoolId])
  @@index([adminId])
  @@index([teacherId])
  @@index([studentId])
  @@index([parentId])
}

model Room {
  id          Int     @id @default(autoincrement())
  name        String // e.g., "Computer Lab A", "Science Lab 1", "Library Section B"
  type        String? // e.g., "Lab", "Standard Classroom", "Auditorium", "Gym"
  capacity    Int? // Max number of occupants
  description String? // Any other relevant details (e.g., "Has 20 PCs", "Projector available")
  schoolId    String
  school      School  @relation("SchoolRooms", fields: [schoolId], references: [id], onDelete: Cascade)

  // Relationships
  lessons        Lesson[]        @relation("RoomLessons") // All lessons scheduled in this room
  lessonSessions LessonSession[] @relation("RoomLessonSessions")
  lessonSessionOverrides LessonSession[] @relation("LessonSessionOverrideRoom")
  events         Event[]         @relation("RoomEvents") // All events scheduled in this room

  examTemplates ExamTemplate[] @relation("RoomExamTemplates")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, schoolId]) // Room names should be unique within a school
}

// ─── Teacher Marketplace ────────────────────────────────────────────────────

model TeacherMarketplaceProfile {
  id        String  @id @default(cuid())
  teacherId String  @unique
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  headline        String?
  bio             String?  @db.Text
  yearsOfExp      Int?
  hourlyRate      Float?
  currency        String   @default("MAD")
  isPublished     Boolean  @default(false)

  subjectTags     String[]
  availableDays   String[]
  maxHoursPerWeek Int?

  city              String?
  country           String?  @default("Morocco")
  willingToRelocate Boolean  @default(false)
  offersOnline      Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SchoolMarketplaceSettings {
  id       String  @id @default(cuid())
  schoolId String  @unique
  school   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  isEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MarketplaceInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
  EXPIRED
}

model MarketplaceInvitation {
  id String @id @default(cuid())

  schoolId  String
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  status  MarketplaceInvitationStatus @default(PENDING)
  message String?                     @db.Text

  proposedHoursPerWeek Int?
  proposedHourlyRate   Float?

  respondedAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement MarketplaceEngagement?

  @@index([teacherId, status])
  @@index([schoolId, status])
}

enum EngagementStatus {
  ACTIVE
  COMPLETED
  TERMINATED
}

model MarketplaceEngagement {
  id String @id @default(cuid())

  invitationId String              @unique
  invitation   MarketplaceInvitation @relation(fields: [invitationId], references: [id])

  schoolId  String
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  membershipId String?

  status    EngagementStatus @default(ACTIVE)
  startDate DateTime         @default(now())
  endDate   DateTime?

  agreedHoursPerWeek Int?
  agreedHourlyRate   Float?
  currency           String @default("MAD")
  totalHoursLogged   Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews MarketplaceReview[]

  @@index([teacherId, status])
  @@index([schoolId, status])
}

enum ReviewerRole {
  SCHOOL
  TEACHER
}

model MarketplaceReview {
  id String @id @default(cuid())

  engagementId   String
  engagement     MarketplaceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  reviewerRole   ReviewerRole
  reviewerAuthId String

  rating  Int
  comment String? @db.Text

  createdAt DateTime @default(now())

  @@unique([engagementId, reviewerRole])
}

model SchoolMarketplaceNeed {
  id       String  @id @default(cuid())
  schoolId String
  school   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  title        String
  description  String?  @db.Text
  subjectTags  String[]
  hoursPerWeek Int?
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications MarketplaceApplication[]

  @@index([schoolId])
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

model MarketplaceApplication {
  id String @id @default(cuid())

  needId    String
  need      SchoolMarketplaceNeed @relation(fields: [needId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  status    ApplicationStatus @default(PENDING)
  message   String?           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([needId, teacherId])
  @@index([teacherId])
}
